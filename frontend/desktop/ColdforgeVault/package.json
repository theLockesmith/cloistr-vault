{
  "name": "cloistr-vault-desktop",
  "productName": "Cloistr Vault",
  "version": "1.0.0",
  "description": "Zero-knowledge password manager for desktop",
  "main": "dist/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "electron-webpack dev",
    "dev:renderer": "electron-webpack dev --renderer",
    "build": "electron-webpack && electron-builder",
    "build:dir": "electron-webpack && electron-builder --dir",
    "build:win": "electron-webpack && electron-builder --win",
    "build:mac": "electron-webpack && electron-builder --mac",
    "build:linux": "electron-webpack && electron-builder --linux",
    "test": "jest",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.cloistr.vault",
    "productName": "Cloistr Vault",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        }
      ]
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "electron-updater": "^6.1.7",
    "axios": "^1.6.2",
    "crypto-js": "^4.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-webpack": "^2.8.2",
    "webpack": "^4.47.0",
    "concurrently": "^8.2.2",
    "typescript": "^5.3.3",
    "@types/crypto-js": "^4.2.1"
  },
  "electronWebpack": {
    "main": {
      "sourceDirectory": "src/main"
    },
    "renderer": {
      "sourceDirectory": "src/renderer"
    }
  },
  "author": {
    "name": "Cloistr Vault Team",
    "email": "hello@cloistr.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/cloistr/vault"
}